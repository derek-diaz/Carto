{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/server",
    "rootDir": ".",
    "noEmit": false,
    "esModuleInterop": true
  },
  "include": [
    "apps/server/src/**/*.ts",
    "packages/core/src/**/*.ts"
  ]
}
